PORT=5001
NODE_ENV=development

# Core
# Include an explicit database name in production, e.g. mongodb+srv://.../careermed
MONGODB_URI=
FRONTEND_URL=https://www.careermed.in

# CORS (comma-separated origins, explicit only)
# Production: include your live frontend domains and any approved preview/staging domains.
CORS_ORIGINS=https://careermed.in,https://www.careermed.in

# JWT
JWT_SECRET=
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=hgh
JWT_REFRESH_EXPIRE=30d

# Email
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# For Gmail SMTP, use the same address as EMAIL_USER unless the alias is verified.
EMAIL_FROM=support@careermed.in

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Optional explicit frontend redirects (OAuth)
OAUTH_SUCCESS_REDIRECT=
OAUTH_FAILURE_REDIRECT=

# OTP development fallback (must stay false in production)
OTP_DEV_FALLBACK=false
OTP_SECRET=

# Pricing / Razorpay
PAID_CHECKOUT_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_DEFAULT=
# Prefer audience-specific mappings. Generic ids are only safe when no two
# audiences share the same app plan id and price.
RAZORPAY_PLAN_ID_EMPLOYER_BASIC=
RAZORPAY_PLAN_ID_EMPLOYER_PREMIUM=
RAZORPAY_PLAN_ID_EMPLOYER_ENTERPRISE=
RAZORPAY_PLAN_ID_JOBSEEKER_BASIC=
RAZORPAY_PLAN_ID_JOBSEEKER_GROWTH=
RAZORPAY_PLAN_ID_JOBSEEKER_PRO=
RAZORPAY_PLAN_ID_BASIC=
RAZORPAY_PLAN_ID_GROWTH=
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_PREMIUM=
RAZORPAY_PLAN_ID_ENTERPRISE=
RAZORPAY_CURRENCY=INR
RAZORPAY_PLAN_PERIOD=monthly
RAZORPAY_PLAN_INTERVAL=1
RAZORPAY_AUTO_CREATE_PLANS=false
RAZORPAY_SUBSCRIPTION_TOTAL_COUNT=12

# Optional: when backend uses a custom subdomain and you want explicit cookie domain
# REFRESH_COOKIE_DOMAIN=.careermed.in
